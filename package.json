{
  "name": "markdown-for-humans-and-ai-agents",
  "displayName": "Markdown for Humans and AI Agents: WYSIWYG Editor",
  "description": "A full-featured WYSIWYG Markdown editor with visual table editing, drag-and-drop images, Mermaid diagrams, and distraction-free writing—all inside VS Code. Includes MCP server for AI agent integration.",
  "version": "1.0.0",
  "publisher": "dksyks",
  "author": {
    "name": "dksyks"
  },
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dksyks/markdown-for-humans-and-AI-Agents"
  },
  "bugs": {
    "url": "https://github.com/dksyks/markdown-for-humans-and-AI-Agents/issues"
  },
  "homepage": "https://github.com/dksyks/markdown-for-humans-and-AI-Agents#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "markdown",
    "editor",
    "wysiwyg",
    "preview",
    "visual",
    "md",
    "table",
    "tables",
    "mermaid",
    "diagram",
    "image",
    "drag-drop",
    "github-flavored-markdown",
    "gfm",
    "notion-like",
    "writing",
    "documentation",
    "readme",
    "formatting",
    "syntax-highlighting",
    "live-preview",
    "full-screen",
    "distraction-free",
    "cover-images",
    "image-resizing",
    "export",
    "html",
    "pdf",
    "docx",
    "human-friendly"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "markdownForHumans.editor",
        "displayName": "Markdown for Humans",
        "selector": [
          {
            "filenamePattern": "*.md",
            "scheme": "file"
          },
          {
            "filenamePattern": "*.markdown",
            "scheme": "file"
          },
          {
            "filenamePattern": "*.md",
            "scheme": "untitled"
          },
          {
            "filenamePattern": "*.markdown",
            "scheme": "untitled"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "markdownForHumans.openFile",
        "title": "Open with Markdown for Humans"
      },
      {
        "command": "markdownForHumans.outline.revealCurrent",
        "title": "Outline: Reveal Current Heading",
        "icon": "$(target)"
      },
      {
        "command": "markdownForHumans.outline.filter",
        "title": "Outline: Filter Headings",
        "icon": "$(search)"
      },
      {
        "command": "markdownForHumans.outline.clearFilter",
        "title": "Outline: Clear Filter",
        "icon": "$(close)"
      },
      {
        "command": "markdownForHumans.getSelection",
        "title": "Get Selection (for AI agents)",
        "category": "Markdown for Humans"
      },
      {
        "command": "markdownForHumans.navigateBack",
        "title": "Go Back",
        "category": "Markdown for Humans",
        "icon": "$(arrow-left)"
      },
      {
        "command": "markdownForHumans.navigateForward",
        "title": "Go Forward",
        "category": "Markdown for Humans",
        "icon": "$(arrow-right)"
      },
      {
        "command": "markdownForHumans.openGotoLine",
        "title": "Go to Line",
        "category": "Markdown for Humans",
        "icon": "$(list-ordered)"
      },
      {
        "command": "markdownForHumans.planOverlay.nextRange",
        "title": "Plan Review: Next Range",
        "category": "Markdown for Humans"
      },
      {
        "command": "markdownForHumans.planOverlay.previousRange",
        "title": "Plan Review: Previous Range",
        "category": "Markdown for Humans"
      }
    ],
    "keybindings": [
      {
        "command": "markdownForHumans.navigateBack",
        "key": "ctrl+alt+left",
        "when": "markdownForHumans.isActive"
      },
      {
        "command": "markdownForHumans.navigateForward",
        "key": "ctrl+alt+right",
        "when": "markdownForHumans.isActive"
      },
      {
        "command": "markdownForHumans.openGotoLine",
        "key": "ctrl+alt+g",
        "when": "markdownForHumans.isActive"
      },
      {
        "command": "markdownForHumans.planOverlay.nextRange",
        "key": "ctrl+alt+]",
        "when": "markdownForHumans.isActive && markdownForHumans.planOverlayActive"
      },
      {
        "command": "markdownForHumans.planOverlay.previousRange",
        "key": "ctrl+alt+[",
        "when": "markdownForHumans.isActive && markdownForHumans.planOverlayActive"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "markdownForHumansOutline",
          "name": "Markdown for Humans: Outline",
          "when": "markdownForHumans.isActive"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "markdownForHumans.openFile",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "markdownForHumans.outline.revealCurrent",
          "when": "view == markdownForHumansOutline",
          "group": "navigation@1"
        },
        {
          "command": "markdownForHumans.outline.filter",
          "when": "view == markdownForHumansOutline && !markdownForHumans.outlineFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "markdownForHumans.outline.clearFilter",
          "when": "view == markdownForHumansOutline && markdownForHumans.outlineFilterActive",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Markdown for Humans",
      "properties": {
        "markdownForHumans.imagePath": {
          "type": "string",
          "default": "images",
          "description": "Folder path for saved images. Interpreted relative to markdownForHumans.imagePathBase."
        },
        "markdownForHumans.imagePathBase": {
          "type": "string",
          "enum": [
            "relativeToDocument",
            "workspaceFolder"
          ],
          "default": "relativeToDocument",
          "description": "Controls whether Image Path is relative to the current markdown file folder or the workspace folder."
        },
        "markdownForHumans.chromePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to Google Chrome or Chromium executable for PDF export. Leave empty to auto-detect.\n\n**Download Chrome:**\n- [Windows/Mac/Linux](https://www.google.com/chrome/)\n- [Chromium (open source)](https://www.chromium.org/getting-involved/download-chromium/)\n\n**Common paths:**\n- **Mac:** `/Applications/Google Chrome.app/Contents/MacOS/Google Chrome`\n- **Windows:** `C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe`\n- **Linux:** `/usr/bin/google-chrome` or `/usr/bin/chromium`"
        },
        "markdownForHumans.imageResize.skipWarning": {
          "type": "boolean",
          "default": false,
          "description": "Skip the warning dialog when resizing images. When enabled, images will be resized immediately without confirmation."
        },
        "markdownForHumans.colors.h1": {
          "type": "string",
          "default": "#1560c1",
          "description": "Text color for Heading 1 (H1)."
        },
        "markdownForHumans.colors.h2": {
          "type": "string",
          "default": "#1560c1",
          "description": "Text color for Heading 2 (H2)."
        },
        "markdownForHumans.colors.h3": {
          "type": "string",
          "default": "#1560c1",
          "description": "Text color for Heading 3 (H3)."
        },
        "markdownForHumans.colors.h4": {
          "type": "string",
          "default": "#1560c1",
          "description": "Text color for Heading 4 (H4)."
        },
        "markdownForHumans.colors.h5": {
          "type": "string",
          "default": "#1560c1",
          "description": "Text color for Heading 5 (H5)."
        },
        "markdownForHumans.colors.h6": {
          "type": "string",
          "default": "#1560c1",
          "description": "Text color for Heading 6 (H6)."
        },
        "markdownForHumans.colors.bold": {
          "type": "string",
          "default": "#bc0101",
          "description": "Text color for bold text."
        },
        "markdownForHumans.colors.italic": {
          "type": "string",
          "default": "#248a57",
          "description": "Text color for italic text."
        },
        "markdownForHumans.colors.boldItalic": {
          "type": "string",
          "default": "#ff7300",
          "description": "Text color for bold-italic text."
        },
        "markdownForHumans.colors.labelOpacity": {
          "type": "number",
          "default": 0.10,
          "minimum": 0,
          "maximum": 1,
          "description": "Opacity of the H1–H6 gutter labels (0 = invisible, 1 = fully opaque)."
        },
        "markdownForHumans.showHeadingGutter": {
          "type": "boolean",
          "default": true,
          "description": "Show H1–H6 labels in the editor gutter."
        },
        "markdownForHumans.showDocumentLineNumbers": {
          "type": "boolean",
          "default": false,
          "description": "Show markdown source line numbers in the document gutter."
        },
        "markdownForHumans.showNavigationLineNumbers": {
          "type": "boolean",
          "default": false,
          "description": "Show markdown source line numbers in the Navigation pane and Explorer outline."
        },
        "markdownForHumans.showNavigationPane": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the navigation pane for documents with headings."
        },
        "markdownForHumans.outlinePanelWidth": {
          "type": "number",
          "default": 220,
          "description": "Width of the navigation pane in pixels."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:release",
    "build:debug": "npm run build:extension:debug && npm run build:webview:debug",
    "build:release": "npm run build:extension:release && npm run build:webview:release && npm run verify-build",
    "verify-build": "node scripts/verify-build.js",
    "build:extension:debug": "node scripts/build-extension.js",
    "build:extension:release": "node scripts/build-extension.js --prod --no-sourcemap",
    "build:webview:debug": "node scripts/build-webview.js",
    "build:webview:release": "node scripts/build-webview.js --prod --no-sourcemap",
    "watch:debug": "concurrently \"npm run watch:extension:debug\" \"npm run watch:webview:debug\"",
    "watch:extension:debug": "node scripts/build-extension.js --watch",
    "watch:webview:debug": "node scripts/build-webview.js --watch",
    "lint": "eslint src --ext ts --max-warnings 600",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "precommit": "npm run lint && npm run test",
    "validate": "npm run lint && npm run test && npm run build:debug",
    "package:release": "vsce package",
    "publish:release": "vsce publish",
    "publish:ovsx:release": "npm run build:release && ovsx publish",
    "install-hooks": "bash ./scripts/install-git-hooks.sh"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/image-size": "^0.7.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vscode/vsce": "^3.7.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-code-block-lowlight": "^3.0.0",
    "@tiptap/extension-image": "^3.0.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-list": "^3.0.0",
    "@tiptap/extension-table": "^3.0.0",
    "@tiptap/markdown": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@types/turndown": "^5.0.4",
    "cheerio": "^1.1.2",
    "docx": "^9.5.1",
    "highlight.js": "^11.11.1",
    "image-size": "^2.0.2",
    "katex": "^0.16.9",
    "lowlight": "^2.9.0",
    "markdown-it": "^14.0.0",
    "mermaid": "^10.6.1",
    "turndown": "^7.1.2"
  }
}
